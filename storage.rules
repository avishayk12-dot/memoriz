rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /events/{eventId}/{allPaths=**} {
      // Anyone can upload images (guests, no auth)
      allow write: if request.resource.size < 20 * 1024 * 1024  // 20MB max
                   && request.resource.contentType.matches('image/.*');
      // Anyone can read (for gallery)
      allow read: if true;
    }
  }
}
