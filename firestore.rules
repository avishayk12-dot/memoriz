rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Events — anyone authenticated (including anonymous) can read
    // Only creator can update/delete
    match /events/{eventId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.createdBy ||
        // Allow incrementing photoCount by anyone (guests uploading)
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['photoCount'])
      );
      allow delete: if request.auth != null && request.auth.uid == resource.data.createdBy;

      // Photos — anyone can add, only creator can delete
      match /photos/{photoId} {
        allow read: if true;
        allow create: if true; // Guests upload without auth
        allow delete: if request.auth != null &&
          get(/databases/$(database)/documents/events/$(eventId)).data.createdBy == request.auth.uid;
      }
    }
  }
}
